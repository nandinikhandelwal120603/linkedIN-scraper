    {
      "parameters": {
        "jsCode": "// Get the response data from the Google Search node\nconst response = $input.first().json;\nconst items = response.items || [];\n\n// --- PAGINATION LOGIC (UNCHANGED) ---\nlet nextStartIndex = 1;\nlet hasMoreResults = false;\n\nif (response.queries && response.queries.nextPage && response.queries.nextPage[0]) {\n  nextStartIndex = response.queries.nextPage[0].startIndex;\n  hasMoreResults = nextStartIndex <= 100; // Google API safety limit\n}\n\n// --- HELPER: EXTRACT PROFILE URL FROM POST URL ---\nfunction extractProfileUrl(postUrl) {\n  if (!postUrl) return \"\";\n\n  // Example:\n  // https://www.linkedin.com/posts/username_some-text\n  const match = postUrl.match(/linkedin\\.com\\/posts\\/([^_\\/]+)/);\n\n  if (match && match[1]) {\n    return `https://www.linkedin.com/in/${match[1]}`;\n  }\n\n  return \"\";\n}\n\n// --- HELPER: EXTRACT DATE FROM SNIPPET ---\nfunction extractDate(snippet) {\n  if (!snippet) return \"Recent\";\n\n  // Matches: \"Jan 9, 2026\" / \"Sep 22, 2025\"\n  const dateMatch = snippet.match(/^[A-Za-z]{3}\\s\\d{1,2},\\s\\d{4}/);\n  return dateMatch ? dateMatch[0] : \"Recent\";\n}\n\n// --- DATA PREPARATION (MATCHES GOOGLE SHEET COLUMNS) ---\nconst results = items.map(item => {\n  const postUrl = item.link || \"\";\n  const postText = item.snippet || \"\";\n\n  return {\n    \"Date Posted\": extractDate(postText),\n    \"Profile URL\": extractProfileUrl(postUrl),\n    \"Summary\": postText,\n    \"Post URL\": postUrl,\n\n    // Pagination data (required downstream)\n    startIndex: nextStartIndex,\n    hasMoreResults: hasMoreResults\n  };\n});\n\n// --- EMPTY STATE HANDLING ---\nif (results.length === 0) {\n  return [{\n    json: {\n      \"Date Posted\": \"N/A\",\n      \"Profile URL\": \"\",\n      \"Summary\": \"\",\n      \"Post URL\": \"\",\n      startIndex: 1,\n      hasMoreResults: false\n    }\n  }];\n}\n\n// Return clean items\nreturn results.map(r => ({ json: r }));\n"
      },
