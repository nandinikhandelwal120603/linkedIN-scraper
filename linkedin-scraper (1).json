    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a strict B2B Lead Qualifier.\nAnalyze the text below.\n\nYour Goal:\nIdentify if the author is a \"BUYER\" (someone looking to hire a developer/agency to build something) or a \"SELLER\" (a freelancer looking for work).\n\nCriteria for \"YES\":\n- Author explicitly says \"looking for a developer\", \"hiring\", \"need to build\", \"seeking co-founder\".\n- Author has a specific project (App, MVP, SaaS, Tool) they need help with.\n\nCriteria for \"NO\":\n- Author says \"I am a developer looking for work\".\n- Author is sharing a tutorial, opinion, or news.\n- Author is asking for career advice.\n- The post is promotional junk.\n\nPost Text:\n{{ $('Extract Results').item.json.Summary }}\nOutput:\nReply with ONLY the word \"YES\" if they are a BUYER.\nReply with ONLY the word \"NO\" for everything else.",
        "batching": {}
