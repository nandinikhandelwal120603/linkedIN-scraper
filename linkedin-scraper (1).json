      "parameters": {
        "jsCode": "// Get all input items from previous node\nconst inputItems = $input.all();\nconsole.log(\"Input items count:\", inputItems.length);\n\n// Defaults\nlet nextStartIndex = 1;\nlet hasMoreResults = false;\n\n// Safely extract pagination info\nif (inputItems.length > 0 && inputItems[0].json) {\n  const data = inputItems[0].json;\n\n  // Preferred fields\n  if (typeof data.startIndex === \"number\") {\n    nextStartIndex = data.startIndex;\n  } else if (typeof data.index === \"number\") {\n    nextStartIndex = data.index;\n  }\n\n  if (typeof data.hasMoreResults === \"boolean\") {\n    hasMoreResults = data.hasMoreResults;\n  } else if (typeof data.results === \"boolean\") {\n    hasMoreResults = data.results;\n  }\n}\n\nconsole.log(\"Next startIndex:\", nextStartIndex);\nconsole.log(\"Has more results:\", hasMoreResults);\n\n// n8n REQUIRES an array return\nreturn [\n  {\n    json: {\n      continueLoop: hasMoreResults,\n      startIndex: nextStartIndex\n    }\n  }\n];\n"
      },
